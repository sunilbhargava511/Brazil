<%- include('partials/header', { title: 'Contact' }) %>

<main>
  <!-- Contact Hero -->
  <section class="contact-hero section-light">
    <div class="container">
      <h1>Start the Conversation</h1>
      <p>Tell us about your group, your dreams for this journey, and we'll start crafting something extraordinary together.</p>
    </div>
  </section>

  <!-- Contact Form -->
  <section class="section section-white">
    <div class="container">
      <div class="contact-content">
        <div class="contact-form-wrapper">
          <% if (submitted) { %>
            <div class="success-message">
              <h2>Thank You</h2>
              <p>We've received your inquiry and will be in touch soon. In the meantime, feel free to explore our Instagram for a glimpse into our world.</p>
              <a href="https://instagram.com/battersbyaraujo" target="_blank" class="btn btn-outline" style="margin-top: 1.5rem; border-color: white; color: white;">Visit Instagram</a>
            </div>
          <% } else { %>
            <form action="/contact" method="POST">
              <div class="form-group">
                <label for="name">Your Name</label>
                <input type="text" id="name" name="name" required>
              </div>

              <div class="form-group">
                <label for="email">Email Address</label>
                <input type="email" id="email" name="email" required>
              </div>

              <div class="form-group">
                <label for="location">Where are you based?</label>
                <input type="text" id="location" name="location" placeholder="City, Country">
              </div>

              <div class="form-group">
                <label for="groupSize">Approximate Group Size</label>
                <select id="groupSize" name="groupSize">
                  <option value="">Select...</option>
                  <option value="4-6">4–6 women</option>
                  <option value="7-9">7–9 women</option>
                  <option value="10-12">10–12 women</option>
                  <option value="unsure">Not sure yet</option>
                </select>
              </div>

              <div class="form-group">
                <label for="timing">When are you thinking of traveling?</label>
                <select id="timing" name="timing">
                  <option value="">Select...</option>
                  <option value="1-3months">In the next 1–3 months</option>
                  <option value="3-6months">In 3–6 months</option>
                  <option value="6-12months">In 6–12 months</option>
                  <option value="exploring">Just exploring for now</option>
                </select>
              </div>

              <div class="form-group">
                <label for="interests">What draws you to Brazil? What kind of experience are you hoping for?</label>
                <textarea id="interests" name="interests" placeholder="Tell us about your group, any special occasions, interests, or dreams for this journey..."></textarea>
              </div>

              <div class="form-group">
                <label for="howFound">How did you hear about us?</label>
                <input type="text" id="howFound" name="howFound" placeholder="Instagram, friend referral, etc.">
              </div>

              <button type="submit" class="btn btn-primary" style="width: 100%;">Send Inquiry</button>
            </form>
          <% } %>
        </div>

        <div class="contact-info">
          <h3>Other Ways to Connect</h3>
          <p>Prefer to reach out directly? We'd love to hear from you however feels most comfortable.</p>

          <div class="contact-details">
            <div class="contact-detail">
              <p class="label">Instagram</p>
              <p class="value"><a href="https://instagram.com/battersbyaraujo" target="_blank">@battersbyaraujo</a></p>
            </div>
            <div class="contact-detail">
              <p class="label">Email</p>
              <p class="value"><a href="mailto:hello@example.com">hello@example.com</a></p>
            </div>
            <div class="contact-detail">
              <p class="label">Based In</p>
              <p class="value">Niterói, Rio de Janeiro, Brazil</p>
            </div>
          </div>

          <div style="margin-top: 3rem; padding: 2rem; background: var(--color-sand);">
            <h3 style="font-size: 1.1rem; margin-bottom: 1rem;">What happens next?</h3>
            <p style="font-size: 0.95rem; color: var(--color-warm-gray); margin-bottom: 0;">Once we receive your inquiry, we'll reach out within 48 hours to schedule a call. This is a chance for us to get to know each other, understand what you're hoping for, and see if we're a good fit to travel together.</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</main>

<%- include('partials/footer') %>
