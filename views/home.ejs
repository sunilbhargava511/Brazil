<%- include('partials/header', { title: 'Home' }) %>

<main>
  <!-- Hero Section -->
  <section class="hero">
    <div class="hero-background"></div>
    <div class="hero-content">
      <p class="hero-tagline fade-in-up">Women-led journeys</p>
      <h1 class="fade-in-up delay-1">Into the Heart<br>of Brazil</h1>
      <p class="hero-subtitle fade-in-up delay-2">Brazil is vast, layered, intense, and often misunderstood. I offer a different way in.</p>
      <a href="/journeys" class="btn btn-primary fade-in-up delay-3">Explore the Journeys</a>
    </div>
  </section>

  <!-- Intro Section -->
  <section class="section section-white">
    <div class="container">
      <div class="intro">
        <div class="intro-text">
          <p class="lead">A way to experience this country with depth, safety and real connection.</p>
          <p>I created Alma Brazil to offer a different way into this country. A way guided by someone who knows how to move through it.</p>
          <p>This is not about ticking places off a list. It's about how a place feels, who you meet, and what stays with you after you leave.</p>
          <p>Brazil reveals itself slowly. In shared meals. In music that spills into the street. In conversations that stay with you.</p>
          <a href="/about" class="btn btn-outline" style="margin-top: 1rem;">About Me</a>
        </div>
        <div class="intro-image">
          <img src="/images/RnFriends.png" alt="Women traveling together in Brazil" class="intro-photo">
        </div>
      </div>
    </div>
  </section>

  <!-- What I Offer -->
  <section class="section section-sand">
    <div class="container">
      <div class="section-header">
        <h2>What I Offer</h2>
        <p>I design and guide tailored journeys for women who want more than surface-level travel.</p>
      </div>
      <div class="features">
        <div class="feature">
          <div class="feature-icon">&#10022;</div>
          <h3>Local Knowledge</h3>
          <p>Over 15 years working across Brazil with international productions. I know how to navigate complexity, anticipate problems and make things flow.</p>
        </div>
        <div class="feature">
          <div class="feature-icon">&#10022;</div>
          <h3>Trusted Connections</h3>
          <p>Access to places and people that feel real, not touristic. Safe, well-positioned accommodation and carefully chosen experiences.</p>
        </div>
        <div class="feature">
          <div class="feature-icon">&#10022;</div>
          <h3>Structure & Freedom</h3>
          <p>I don't follow scripts or fixed itineraries. I design each journey around you, then hold the experience so you can relax into it.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Journey Previews -->
  <section class="section section-white">
    <div class="container">
      <div class="section-header">
        <h2>The Journeys</h2>
        <p>Three experiences, each designed around a different rhythm of Brazil.</p>
      </div>
      <div class="journey-cards">
        <a href="/journeys/rio" class="journey-card">
          <div class="journey-card-label">4 days</div>
          <h3>Rio: The Soft Landing</h3>
          <p>A grounded introduction to Brazil. I guide you into the rhythm of the city, so you don't just visit it — you start to feel comfortable in it.</p>
          <span class="journey-card-link">Learn more &rarr;</span>
        </a>
        <a href="/journeys/bahia" class="journey-card">
          <div class="journey-card-label">5-7 days</div>
          <h3>Bahia: Culture & Depth</h3>
          <p>Salvador and beyond. An experience of Bahia that moves between the intensity of the city and quieter coastal towns where time slows down.</p>
          <span class="journey-card-link">Learn more &rarr;</span>
        </a>
        <a href="/journeys/nature" class="journey-card">
          <div class="journey-card-label">3-5 days</div>
          <h3>Nature Reset</h3>
          <p>Mountains and coast around Rio. Designed to take you out of the intensity of the city and into space, stillness and nature.</p>
          <span class="journey-card-link">Learn more &rarr;</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Who This Is For -->
  <section class="section section-sand">
    <div class="container">
      <div class="section-header" style="margin-bottom: 0;">
        <h2>Who This Is For</h2>
        <ul class="audience-list">
          <li>Women who want to explore Brazil but not alone</li>
          <li>Women who value connection over tourism</li>
          <li>Women who want to feel safe without feeling restricted</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="section section-light">
    <div class="container">
      <div class="section-header" style="margin-bottom: 2rem;">
        <h2>Ready to Begin?</h2>
        <p>Tell me a little about you and what you're looking for. I'll shape something around you.</p>
        <a href="/contact" class="btn btn-primary" style="margin-top: 2rem;">Start the Conversation</a>
      </div>
    </div>
  </section>
</main>

<%- include('partials/footer') %>
